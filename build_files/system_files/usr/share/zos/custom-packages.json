[
  {
    "name": "Snapmaker Orca",
    "description": "3D printing slicer by Snapmaker",
    "search_terms": ["orca", "orcaslicer", "snapmaker", "slicer", "3d"],
    "install_type": "github-appimage",
    "github_repo": "Snapmaker/OrcaSlicer",
    "asset_pattern": "*Linux_AppImage_Ubuntu2404*.AppImage",
