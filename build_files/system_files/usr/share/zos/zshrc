# =============================================================================
# zOS ZSH Configuration (system-managed)
# User customizations go in ~/.zshrc — this file is managed by zOS
# =============================================================================

# --- Deduplicate PATH (prevents duplicates on re-source) ---
typeset -U PATH path

# --- History ---
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_SAVE_NO_DUPS
setopt SHARE_HISTORY

# --- Completion (skip if Oh My Zsh is actually loaded) ---
if [[ -z "$ZSH_COMPDUMP" ]]; then
    autoload -Uz compinit
    compinit
    zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
    zstyle ':completion:*' menu select
fi

# --- Claude Code (force zsh shell) ---
alias claude='SHELL=/usr/bin/zsh command claude'

# --- Aliases ---
alias ls='eza --icons'
alias ll='eza -la --icons --git'
alias lt='eza --tree --icons -L 2'
alias cat='bat --paging=never'
alias grep='rg'
alias find='fd'
alias diff='delta'
alias top='btop'
alias du='dust'
alias df='duf'
alias ps='procs'
alias http='xh'
alias dig='doggo'
alias ..='cd ..'
alias ...='cd ../..'

# --- Git aliases ---
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph -20'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias lg='lazygit'
alias ld='lazydocker'

# --- Docker/Podman ---
alias docker='podman'
alias dc='podman-compose'

# --- Rust/Cargo (user toolchain via rustup) ---
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# --- Homebrew (if installed via first-login) ---
if [ -d "$HOME/.linuxbrew" ]; then
    eval "$($HOME/.linuxbrew/bin/brew shellenv)"
elif [ -d "/home/linuxbrew/.linuxbrew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# --- mise (dev tool version manager) ---
if command -v mise &> /dev/null; then
    eval "$(mise activate zsh)"
fi

# --- zoxide (smart cd) ---
if command -v zoxide &> /dev/null; then
    eval "$(zoxide init zsh)"
fi

# --- fzf ---
if command -v fzf &> /dev/null; then
    source <(fzf --zsh) 2>/dev/null || true
fi

# --- atuin (shell history search) ---
if command -v atuin &> /dev/null; then
    eval "$(atuin init zsh)"
fi

# --- direnv (per-directory env vars) ---
if command -v direnv &> /dev/null; then
    eval "$(direnv hook zsh)"
fi

# --- Android SDK (prefer user override under $HOME, else system) ---
if [ -d "$HOME/Android/Sdk" ]; then
    export ANDROID_HOME="$HOME/Android/Sdk"
elif [ -d /usr/lib/android-sdk ]; then
    export ANDROID_HOME=/usr/lib/android-sdk
fi

if [ -n "${ANDROID_HOME:-}" ]; then
    export ANDROID_SDK_ROOT="$ANDROID_HOME"
    export PATH="$PATH:$ANDROID_HOME/platform-tools:$ANDROID_HOME/cmdline-tools/latest/bin"
fi

# --- Java ---
if [ -d /usr/lib/jvm/java-21-openjdk ]; then
    export JAVA_HOME=/usr/lib/jvm/java-21-openjdk
fi

# --- Starship prompt (fallback if not using Oh My Zsh / p10k) ---
if [[ -z "$ZSH_THEME" ]] && command -v starship &> /dev/null; then
    eval "$(starship init zsh)"
fi
