// === 50-zos-passwordless.rules ===
//
// Allow members of the `wheel` group with an active session to run a curated
// list of root binaries via `pkexec` without a password prompt.
//
// This is required for UI contexts (wlogout, zos-power, zos-launcher) that
// have no TTY and no graphical polkit agent at invocation time -- typical for
// "Reboot to Windows" buttons fired during logout/reboot.
//
// SCOPE: this rule only affects users in `wheel` with an active session.
// Inactive sessions, non-wheel users, and remote sessions still fall through
// to default polkit policy (auth_admin / password prompt).
//
// ADDING ENTRIES: extend the `allowed` array. Audio/PipeWire tooling does
// NOT belong here -- it runs entirely in user space and never needs root.
// Destructive commands (rpm-ostree, grub2-mkconfig) should be gated behind a
// settings-level confirmation flow, not blanket-allowed here.

polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.policykit.exec") {
        return undefined;
    }
    if (!subject.isInGroup("wheel")) {
        return undefined;
    }
    if (!subject.active) {
        return undefined;
    }

    var program = action.lookup("program");
    if (!program) {
        return undefined;
    }

    var allowed = [
        "/usr/sbin/efibootmgr",
        "/usr/bin/efibootmgr"
    ];

    for (var i = 0; i < allowed.length; i++) {
        if (program === allowed[i]) {
            return polkit.Result.YES;
        }
    }

    return undefined;
});
