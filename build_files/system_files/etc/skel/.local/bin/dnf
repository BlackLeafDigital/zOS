echo ""
echo "Install software using:"
echo "  flatpak install <app>     — GUI applications"
echo "  brew install <package>    — CLI tools (Homebrew)"
echo "  distrobox enter           — Full mutable Linux environment"
echo "  rpm-ostree install <pkg>  — System packages (requires reboot)"
